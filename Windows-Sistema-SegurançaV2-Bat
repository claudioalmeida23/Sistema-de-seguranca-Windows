@echo off
setlocal EnableDelayedExpansion
chcp 65001 >nul
title SISTEMA DE DEFESA v2.1 - CAAS
set "CRIADOR=Claudio Almeida"
color 0A

:: =====================================
:: AUTO ELEVAR PARA ADMIN
:: =====================================
>nul 2>&1 net session
if %errorLevel% neq 0 (
    powershell -Command "Start-Process -FilePath '%~f0' -Verb RunAs"
    exit /b
)

:: =====================================
:: CONFIGURACOES
:: =====================================
set "VERSAO=v3.1"
set "SYN_LIMIT=15"
set "LOG_FILE=cyber_defense.log"
set "MEMORY_FILE=blocked_ips.tmp"

if not exist "%LOG_FILE%" echo [%date% %time%] - CAAS INICIADO >> "%LOG_FILE%"
if exist "%MEMORY_FILE%" del "%MEMORY_FILE%"

where nmap >nul 2>&1
if %errorlevel% neq 0 (set NMAP=0) else (set NMAP=1)

:: =====================================
:MENU
cls
call :HEADER
echo.
echo  [1] Diagnostico de Rede
echo  [2] Escaneamento Avancado (Nmap)
echo  [3] ESCUDO ATIVO CAAS
echo  [4] Hardening e Stealth (Blindagem)
echo  [5] Ferramentas
echo  [6] Limpar Regras e Memoria
echo  [0] Sair
echo.
set /p op="CAAS > "

if "%op%"=="1" goto REDE
if "%op%"=="2" goto SCAN
if "%op%"=="3" goto DEFESA
if "%op%"=="4" goto HARDENING
if "%op%"=="5" goto TOOLS
if "%op%"=="6" goto CLEAR
if "%op%"=="0" goto EXIT
goto MENU

:: =====================================
:HEADER
echo.
echo   ██████╗  █████╗  █████╗  ███████╗
echo  ██╔════╝ ██╔══██╗██╔══██╗ ██╔════╝
